# Formspree form endpoint for the "Contact this person" relay.
# Create a free form at https://formspree.io, then paste the endpoint URL here.
# In Vercel: Settings → Environment Variables → add NEXT_PUBLIC_FORMSPREE_ENDPOINT.
# Redeploy after setting so the client bundle picks up the new value.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
